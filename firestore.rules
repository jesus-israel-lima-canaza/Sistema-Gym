rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); } // Relaxed for email/password support
    function getProfile() { return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data; }
    function isAdmin() { 
      return isVerified() && (
        getProfile().role == 'admin' || 
        request.auth.token.email.lower() == 'jesus.israel.lima.canaza@gmail.com'
      ); 
    }
    function isStaff() { 
      return isVerified() && (
        getProfile().role in ['admin', 'manager', 'staff', 'cashier']
      ); 
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Profiles
    match /profiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && 
        incoming().keys().hasAll(['role', 'email']) &&
        incoming().role in ['admin', 'manager', 'staff', 'cashier'] &&
        (incoming().role in ['manager', 'staff', 'cashier'] || request.auth.token.email == 'Jesus.Israel.Lima.Canaza@gmail.com');
      allow update: if isAdmin();
      allow delete: if isAdmin() && userId != request.auth.uid; // Prevent self-delete
    }

    // Members
    function isValidMember(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.gender in ['male', 'female', 'other'] &&
             data.age is number && data.age >= 0 && data.age <= 120 &&
             data.planId is string &&
             data.status in ['active', 'inactive'];
    }
    match /members/{memberId} {
      allow read, list: if isStaff();
      allow create: if isStaff() && isValidMember(incoming());
      allow update: if isStaff() && isValidMember(incoming());
      allow delete: if isAdmin();
    }

    // Plans
    match /plans/{planId} {
      allow read, list: if isStaff();
      allow write: if isAdmin();
    }

    // Payments
    match /payments/{paymentId} {
      allow read, list: if isStaff();
      allow create: if isStaff() && 
        incoming().amount is number && incoming().amount >= 0 &&
        incoming().type in ['membership', 'product', 'service'] &&
        incoming().cashierId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Check-ins
    match /checkins/{checkInId} {
      allow read, list: if isStaff();
      allow create: if isStaff() && incoming().memberId is string;
      allow update, delete: if isAdmin();
    }

    // Inventory
    match /inventory/{itemId} {
      allow read, list: if isStaff();
      allow create: if isAdmin();
      allow update: if isStaff() && (
        isAdmin() || 
        (incoming().diff(existing()).affectedKeys().hasOnly(['stock']))
      );
      allow delete: if isAdmin();
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow read, list, write: if isStaff();
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read, list, write: if isAdmin();
    }
  }
}
